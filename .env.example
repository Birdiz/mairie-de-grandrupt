# Copy to .env.local and fill in real values.

# ─── Resend (contact form) ───────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_EMAIL_TO=communedegrandrupt@orange.fr
CONTACT_EMAIL_FROM=noreply@grandrupt.fr

# ─── Payload CMS ──────────────────────────────────────────────────────────────
# Long random string used to sign auth tokens. Generate with:
#   openssl rand -base64 32
PAYLOAD_SECRET=change-me-to-a-long-random-secret

# SQLite database location (libsql URL). Relative to the app working directory.
# In Docker this resolves to /app/data/payload.db (mounted as a volume).
DATABASE_URI=file:./data/payload.db

# ─── Déploiement (auto-hébergé) ──────────────────────────────────────────────
# Domaine public du site, utilisé par Caddy pour le certificat HTTPS auto
# (Let's Encrypt). Laisser vide en local (Caddy sert https://localhost auto-signé).
SITE_DOMAIN=mairie-grandrupt.fr
# URL publique absolue (sitemap.xml, balises SEO).
NEXT_PUBLIC_SITE_URL=https://mairie-grandrupt.fr
